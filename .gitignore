cat > .gitignore <<EOF
# --- 常用 Java/Maven 忽略项 ---
target/
*.class
*.log
logs/

# --- IDE 配置文件 (不需要上传) ---
.idea/
*.iml
*.ipr
*.iws
.vscode/

# --- macOS 系统文件 ---
.DS_Store

# --- 本项目特定忽略项 ---
# 忽略测试生成的 token 文件
src/test/java/com/hmdp/tokens.txt
# 如果你想忽略所有测试生成的临时 txt 文件，也可以写 *.txt

# --- 敏感信息 (防止误传) ---
# 真正的密钥配置文件建议忽略，但这只是学习项目，application.yaml 可以留着
# config/application-prod.yaml
EOF